// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "active_pane_modifiers": {
    "inactive_opacity": 1.0
  },
  "diff_view_style": "unified",
  "vim": {
    "default_mode": "normal"
  },
  "diagnostics": {
    "inline": {
      "enabled": true
    }
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Zed (Default)"
  },
  "tab_size": 2,
  "debugger": {
    "dock": "left"
  },
  "terminal": {
    "font_family": "FiraCode Nerd Font"
  },
  "restore_on_startup": "last_workspace",
  "which_key": {
    "delay_ms": 200,
    "enabled": true
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000
    }
  },
  "agent_servers": {
    "codex-acp": {
      "type": "registry"
    }
  },
  "ssh_connections": [
    {
      "host": "172.24.5.184",
      "args": [],
      "projects": [
        {
          "paths": [
            "/home/clo91eaf/Project/circt"
          ]
        },
        {
          "paths": [
            "/home/clo91eaf/Project/zaozi"
          ]
        }
      ]
    }
  ],
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "right"
  },
  "agent": {
    "play_sound_when_agent_done": "never",
    "sidebar_side": "right",
    "dock": "right",
    "favorite_models": [],
    "model_parameters": []
  },
  "git_panel": {
    "dock": "left"
  },
  "base_keymap": "VSCode",
  "vim_mode": true,
  "ui_font_size": 16,
  "buffer_font_size": 16,
  "theme": {
    "mode": "dark",
    "light": "Tokyo Night Light",
    "dark": "Catppuccin Mocha (Blur)"
  },
  "inlay_hints": {
    "enabled": true,
    "show_type_hints": true,
    "show_parameter_hints": true,
    "show_other_hints": true,
    "show_background": false,
    "edit_debounce_ms": 700,
    "scroll_debounce_ms": 50
  },
  "lsp": {
    "metals": {
      "binary": {
        "arguments": [
          "-Dmetals.http=on"
        ]
      },
      "initialization_options": {
        "isHttpEnabled": true
      },
      "settings": {
        "inlayHints": {
          "inferredTypes": {
            "enable": true
          },
          "implicitArguments": {
            "enable": true
          },
          "implicitConversions": {
            "enable": true
          },
          "typeParameters": {
            "enable": true
          },
          "hintsInPatternMatch": {
            "enable": true
          }
        }
      }
    }
  }
}