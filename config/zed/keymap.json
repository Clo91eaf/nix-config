// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {
      // "shift shift": "file_finder::Toggle"
    }
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      // "j k": "vim::NormalBefore"
    }
  },
  {
    "context": "Pane",
    "unbind": {
      "ctrl-shift-g": "search::SelectPreviousMatch"
    }
  },
  {
    "bindings": {
      "ctrl-g": "git_panel::Toggle"
    }
  },
  {
    "bindings": {
      "ctrl-b": "project_panel::Toggle"
    }
  },
  {
    "context": "Workspace",
    "unbind": {
      "ctrl-b": "workspace::ToggleLeftDock"
    }
  },
  {
    "bindings": {
      "ctrl-i": "agent::Toggle"
    }
  },
  {
    "context": "ThreadsSidebar",
    "unbind": {
      "ctrl-g": "agents_sidebar::ToggleThreadHistory"
    }
  },
  {
    "context": "Pane",
    "unbind": {
      "ctrl-g": "search::SelectNextMatch"
    }
  },
  {
    "context": "(VimControl && !menu) || (!Editor && !Terminal)",
    "bindings": {
      "alt-j": "vim::GoToPreviousTab"
    }
  },
  {
    "context": "(VimControl && !menu) || (!Editor && !Terminal)",
    "unbind": {
      "g shift-t": "vim::GoToPreviousTab"
    }
  },
  {
    "context": "(VimControl && !menu) || (!Editor && !Terminal)",
    "bindings": {
      "alt-k": "vim::GoToTab"
    }
  },
  {
    "context": "(VimControl && !menu) || (!Editor && !Terminal)",
    "unbind": {
      "g t": "vim::GoToTab"
    }
  },
  {
    "context": "Workspace",
    "unbind": {
      "ctrl-j": "workspace::ToggleBottomDock"
    }
  },
  {
    "context": "FileFinder || FileFinder > Picker > Editor || FileFinder > Picker > menu",
    "unbind": {
      "ctrl-j": "pane::SplitDown"
    }
  },
  {
    "context": "FileFinder || FileFinder > Picker > Editor || FileFinder > Picker > menu",
    "unbind": {
      "ctrl-j": "pane::SplitDown"
    }
  },
  {
    "context": "FileFinder || FileFinder > Picker > Editor || FileFinder > Picker > menu",
    "unbind": {
      "ctrl-j": "pane::SplitDown"
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "alt-shift-f": "editor::Format"
    }
  },
  {
    "context": "Editor",
    "unbind": {
      "ctrl-shift-i": "editor::Format"
    }
  },
  {
    "context": "vim_mode == replace",
    "unbind": {
      "ctrl-shift-v": "editor::Paste"
    }
  },
  {
    "unbind": {
      "ctrl-o": "workspace::Open"
    }
  },
  {
    "context": "Workspace",
    "unbind": {
      "ctrl-shift-g": "git_panel::ToggleFocus"
    }
  },
  {
    "context": "vim_mode == insert",
    "unbind": {
      "ctrl-w": [
        "editor::DeleteToPreviousWordStart",
        {
          "ignore_newlines": false,
          "ignore_brackets": false
        }
      ]
    }
  },
  {
    "context": "Picker > Editor",
    "unbind": {
      "ctrl-w": "editor::DeleteToPreviousWordStart"
    }
  },
  {
    "context": "vim_mode == literal",
    "unbind": {
      "ctrl-w": [
        "vim::Literal",
        [
          "ctrl-w",
          "\u0017"
        ]
      ]
    }
  },
  {
    "context": "SettingsWindow",
    "bindings": {
      "ctrl-w": "workspace::CloseWindow"
    }
  },
  {
    "context": "(VimControl && !menu) || (!Editor && !Terminal)",
    "unbind": {
      "ctrl-w +": "vim::ResizePaneUp"
    }
  },
  {
    "context": "(VimControl && !menu) || (!Editor && !Terminal)",
    "unbind": {
      "ctrl-w -": "vim::ResizePaneDown"
    }
  },
  {
    "context": "(VimControl && !menu) || (!Editor && !Terminal)",
    "unbind": {
      "ctrl-w <": "vim::ResizePaneLeft"
    }
  },
  {
    "context": "(VimControl && !menu) || (!Editor && !Terminal)",
    "unbind": {
      "ctrl-w >": "vim::ResizePaneRight"
    }
  },
  {
    "context": "(VimControl && !menu) || (!Editor && !Terminal)",
    "unbind": {
      "ctrl-w =": "vim::ResetPaneSizes"
    }
  },
  {
    "context": "(VimControl && !menu) || (!Editor && !Terminal)",
    "unbind": {
      "ctrl-w _": "vim::MaximizePane"
    }
  },
  {
    "context": "Editor && edit_prediction",
    "unbind": {
      "alt-j": "editor::AcceptNextLineEditPrediction"
    }
  },
  {
    "context": "Editor && edit_prediction",
    "unbind": {
      "alt-k": "editor::AcceptNextWordEditPrediction"
    }
  }
]
